{
  "name": "symphony-setup",
  "version": "1.0.0",
  "description": "Linear の symphony ラベル & Backlog プロジェクトを走査し、リポジトリを作成/追跡する symphony-setup 本体 (bun + TypeScript)",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build --compile --outfile ~/.local/bin/symphony-setup src/index.ts",
    "deploy": "bash scripts/deploy.sh"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^7.0.2"
  }
}
